= govuk_summary_list(classes: 'govuk-summary-list--no-border app-summary-list_sidebar') do |summary_list|
  - summary_list.with_row do |row|
    - row.with_key(html_attributes: { class: 'fx-seed-gradFees', data: { seed: claim.raw_basic_fees_total, autovat: @claim.apply_vat? ? 'true' : 'false' } }) { t('.graduated_fees') }
    - row.with_value(text: claim.basic_fees_total, classes:'total-gradFees')

  - summary_list.with_row do |row|
    - row.with_key(html_attributes: { class: 'fx-seed-miscFees', data: { seed: claim.raw_misc_fees_total, autovat: @claim.apply_vat? ? 'true' : 'false' } }) { t('.miscellaneous_fees') }
    - row.with_value(text: claim.misc_fees_total, classes: 'total-miscFees')

  - summary_list.with_row do |row|
    - row.with_key(html_attributes: { class: 'fx-seed-expenses', data: { seed: claim.raw_expenses_total, autovat: @claim.apply_vat? ? 'true' : 'false' } }) { t('.travel_expenses') }
    - row.with_value(text: claim.expenses_total, classes: 'total-expenses')

  - summary_list.with_row do |row|
    - row.with_key(html_attributes: { class: 'fx-seed', 'data-vat-total': claim.raw_vat_amount }) { t('.vat') }
    - row.with_value(text: claim.vat_amount, classes: 'total-vat')

  - summary_list.with_row do |row|
    - row.with_key(html_attributes: { class: 'fx-seed', 'data-total-inc': claim.raw_total_inc }) { t('.total') }
    - row.with_value(text: claim.total_inc, classes: 'total-grandTotal')
