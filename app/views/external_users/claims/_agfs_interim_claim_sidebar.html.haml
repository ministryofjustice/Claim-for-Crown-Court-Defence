= govuk_summary_list(classes: 'govuk-summary-list--no-border app-summary-list_sidebar') do |summary_list|
  - summary_list.with_row do |row|
    - row.with_key(html_attributes: { class: 'fx-seed-interimFees', data: { seed: claim.raw_warrant_fees_total, autovat: @claim.apply_vat? ? 'true' : 'false' } }) do
      = t('.interim_fees')
    - row.with_value(html_attributes: { class: 'total-interimFees' }) do
      = claim.warrant_fees_total

  - summary_list.with_row do |row|
    - row.with_key(html_attributes: { class: 'fx-seed-expenses', data: { seed: claim.raw_expenses_total, autovat: @claim.apply_vat? ? 'true' : 'false' } }) do
      = t('.travel_expenses')
    - row.with_value(html_attributes: { class: 'total-expenses' }) do
      = claim.expenses_total

  - summary_list.with_row do |row|
    - row.with_key(html_attributes: { class: 'fx-seed', 'data-vat-total': claim.raw_vat_amount }) do
      = t('.vat')
    - row.with_value(html_attributes: { class: 'total-vat' }) do
      = claim.vat_amount

  - summary_list.with_row do |row|
    - row.with_key(html_attributes: { class: 'fx-seed', 'data-total-inc': claim.raw_total_inc }) do
      = t('.total')
    - row.with_value(html_attributes: { class: 'total-grandTotal' }) do
      = claim.total_inc
