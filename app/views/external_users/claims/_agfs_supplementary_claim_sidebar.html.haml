= govuk_summary_list(classes: 'govuk-summary-list--no-border') do |summary_list|

  - summary_list.with_row do |row|
    - row.with_key do
      %span.fx-seed-miscFees{ data: { seed: claim.raw_misc_fees_total, autovat: @claim.apply_vat? ? 'true' : 'false' } }
        = t('external_users.claims.agfs_supplementary_claim_sidebar.miscellaneous_fees')
    - row.with_value(text: claim.misc_fees_total, classes: 'total-miscFees')

  - summary_list.with_row do |row|
    - row.with_key do
      %span.fx-seed-expenses{ data: { seed: claim.raw_expenses_total, autovat: @claim.apply_vat? ? 'true' : 'false' } }
        = t('external_users.claims.agfs_supplementary_claim_sidebar.travel_expenses')
    - row.with_value(text: claim.expenses_total, classes: 'total-expenses')

  - summary_list.with_row do |row|
    - row.with_key do
      %span.fx-seed{ 'data-vat-total': claim.raw_vat_amount }
        = t('external_users.claims.agfs_supplementary_claim_sidebar.vat')
    - row.with_value(text: claim.vat_amount, classes: 'total-vat')

  - summary_list.with_row do |row|
    - row.with_key do
      %span.fx-seed{ 'data-total-inc': claim.raw_total_inc }
        = t('external_users.claims.agfs_supplementary_claim_sidebar.total')
    - row.with_value(text: claim.total_inc, classes: 'total-grandTotal')
