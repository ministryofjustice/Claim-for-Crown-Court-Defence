= govuk_summary_list(classes: 'govuk-summary-list--no-border app-summary-list_sidebar') do |summary_list|
  - summary_list.with_row do |row|
    - row.with_key do
      %span.fx-seed-interimFees{ data: { seed: claim.raw_interim_fees_total, autovat: @claim.apply_vat? ? 'true' : 'false' } }
        = t('.interim_fees')
    - row.with_value do
      %div.total-interimFees= claim.interim_fees_total

  - summary_list.with_row do |row|
    - row.with_key do
      %span.fx-seed-disbursements{ data: { seed: claim.raw_disbursements_total, autovat: 'false', 'seed-vat': claim.raw_disbursements_vat } }
        = t('.disbursements')
    - row.with_value do
      %div.total-disbursements= claim.disbursements_total

  - summary_list.with_row do |row|
    - row.with_key do
      %span.fx-seed-expenses{ data: { seed: claim.raw_expenses_total, autovat: 'false', 'seed-vat': claim.raw_expenses_vat } }
        = t('.travel_expenses')
    - row.with_value do
      %div.total-expenses= claim.expenses_total

  - summary_list.with_row do |row|
    - row.with_key do
      %span.fx-seed{ 'data-vat-total': claim.raw_vat_amount }
        = t('.vat')
    - row.with_value do
      %div.total-vat= claim.vat_amount

  - summary_list.with_row do |row|
    - row.with_key do
      %span.fx-seed{ 'data-total-inc': claim.raw_total_inc }
        = t('.total')
    - row.with_value do
      %div.total-grandTotal= claim.total_inc
