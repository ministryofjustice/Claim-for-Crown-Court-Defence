%h3.govuk-heading-m
  = t('.certification_box_title')

= govuk_summary_list do |summary_list|
  - summary_list.with_row do |row|
    - row.with_key(text: t('.instructed_heading'))
    - row.with_value { claim.external_user.name }

  - if @claim.agfs?
    - summary_list.with_row do |row|
      - row.with_key(text: t('.certification_reason'))
      - row.with_value { claim.certification&.certification_type&.name || '' }
