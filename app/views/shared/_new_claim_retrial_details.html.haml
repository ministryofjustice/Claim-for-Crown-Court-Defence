- summary_list.with_row do |row|
  - row.with_key(text: t('.retrial_started_at'))
  - row.with_value(text: claim&.retrial_started_at&.strftime(Settings.date_format) )

- summary_list.with_row do |row|
  - row.with_key(text: t('.retrial_estimated_length'))
  - row.with_value(text: claim&.retrial_estimated_length )

- summary_list.with_row do |row|
  - row.with_key(text: t('.retrial_actual_length'))
  - row.with_value(text: claim&.retrial_actual_length )

- summary_list.with_row do |row|
  - row.with_key(text: t('.retrial_concluded_at'))
  - row.with_value(text: claim&.retrial_concluded_at&.strftime(Settings.date_format) )

- summary_list.with_row do |row|
  - row.with_key(text: t('.retrial_reduction'))
  - row.with_value(text: claim&.retrial_reduction? ? 'Yes' : 'No' )
