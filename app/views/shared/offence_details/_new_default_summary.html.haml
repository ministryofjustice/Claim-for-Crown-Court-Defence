- summary_list.with_row do |row|
  - row.with_key(text: t('offence_category', scope: claim_fields) )
  - row.with_value { claim.offence&.description || t('general.not_provided') }

- summary_list.with_row do |row|
  - row.with_key(text:  t('offence_class', scope: claim_fields))
  - row.with_value { claim.offence&.offence_class || t('general.not_provided') }
