- summary_list.with_row do |row|
  - row.with_key { t('offence_band', scope: claim_fields) }
  - row.with_value { claim.offence&.offence_band&.description || t('general.not_provided') }

- summary_list.with_row do |row|
  - row.with_key { t('offence_category', scope: claim_fields) }
  - row.with_value { claim.offence&.description || t('general.not_provided') }
